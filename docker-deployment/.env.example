# =============================================================================
# Claude Code Remote Dev Environment - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# =============================================================================

# --- Required ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Web terminal ---
TTYD_PORT=7681
# Set credentials for web terminal auth (format: user:password)
# TTYD_CREDENTIAL=developer:changeme

# --- Git (optional, set for automatic git config) ---
# GIT_USER_NAME=Your Name
# GIT_USER_EMAIL=you@example.com
