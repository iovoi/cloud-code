[Unit]
Description=Claude Code Web Terminal (ttyd)
# ttyd is reachable only through the Tailscale serve proxy, so make sure
# tailscaled is up first. (tailscale serve config is restored by tailscaled.)
After=network-online.target tailscaled.service
Wants=network-online.target tailscaled.service

[Service]
Type=simple
User=developer
Group=developer
WorkingDirectory=/home/developer/workspace

# Load PATH so Node.js / nvm binaries are available
Environment=PATH=/home/developer/.nvm/versions/node/current/bin:/usr/local/bin:/usr/bin:/bin
Environment=LANG=en_US.UTF-8
Environment=LC_ALL=en_US.UTF-8
Environment=NVM_DIR=/home/developer/.nvm
# gcloud (used to fetch secrets) writes config under $HOME.
Environment=HOME=/home/developer

ExecStart=/home/developer/start.sh
Restart=on-failure
RestartSec=5

# Security hardening
NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/home/developer /tmp

[Install]
WantedBy=multi-user.target
