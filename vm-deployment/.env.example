# =============================================================================
# Claude Code VM Dev Environment - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# =============================================================================

# --- Required ---
# Set ONE of these for the Anthropic API key:
#   ANTHROPIC_API_KEY        = plaintext key (simple, kept on disk)
#   ANTHROPIC_API_KEY_SECRET = name of a GCP Secret Manager secret (preferred)
# ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_API_KEY_SECRET=anthropic-api-key

# --- GCP Secret Manager (required if any *_SECRET var is set) ---
# The VM's service account must have roles/secretmanager.secretAccessor.
GCP_PROJECT=your-gcp-project-id

# --- Web terminal ---
TTYD_PORT=7681
# ttyd binds to this interface only. Keep 127.0.0.1 so it is reachable solely
# through the Tailscale serve proxy (never directly exposed).
TTYD_INTERFACE=127.0.0.1
# Optional extra auth on top of Tailscale access control (format: user:password).
# Set ONE: plaintext TTYD_CREDENTIAL, or TTYD_CREDENTIAL_SECRET (Secret Manager).
# TTYD_CREDENTIAL=developer:changeme
# TTYD_CREDENTIAL_SECRET=ttyd-credential

# --- Tailscale (used by setup.sh for non-interactive provisioning) ---
# Tailscale node name shown in your tailnet (also the web terminal hostname).
TAILSCALE_HOSTNAME=claude-code
# Reusable auth key from https://login.tailscale.com/admin/settings/keys
# Set ONE: plaintext TAILSCALE_AUTH_KEY, or TAILSCALE_AUTH_KEY_SECRET (Secret Manager).
# Leave both blank to run `tailscale up` manually (it prints an auth URL).
# TAILSCALE_AUTH_KEY=tskey-auth-...
TAILSCALE_AUTH_KEY_SECRET=tailscale-auth-key
# Serve over HTTP (default) or HTTPS. HTTP is still encrypted end-to-end by the
# WireGuard tunnel; the browser just shows "Not secure". For HTTPS, first enable
# "HTTPS Certificates" on the tailnet in the Tailscale admin console, then set true.
TAILSCALE_SERVE_HTTPS=false

# --- Git (optional, set for automatic git config) ---
# GIT_USER_NAME=Your Name
# GIT_USER_EMAIL=you@example.com
